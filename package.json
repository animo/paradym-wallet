{
	"name": "wallets",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm -r build",
		"upgrade:tamagui": "pnpm up '*tamagui*'@latest '@tamagui/*'@latest",
		"upgrade:tamagui:canary": "pnpm up '*tamagui*'@canary '@tamagui/*'@canary",
		"deps:fix": "pnpm deps:check --fix",
		"types:check": "tsc --noEmit",
		"style:check": "biome check --unsafe",
		"style:fix": "biome check --write --unsafe",
		"release:sdk": "pnpm build && pnpm changeset publish --no-git-tag",
		"changeset-version:sdk": "pnpm changeset version && pnpm style:fix"
	},
	"engines": {
		"node": ">=22.21.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.10",
		"@changesets/cli": "^2.29.4",
		"check-dependency-version-consistency": "^5.0.1",
		"typescript": "catalog:"
	},
	"packageManager": "pnpm@11.7.0"
}
